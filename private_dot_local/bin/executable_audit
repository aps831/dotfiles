#! /bin/bash

if [[ -f "pom.xml" ]]; then

    mvn org.owasp:dependency-check-maven:check -DfailBuildOnAnyVulnerability=true

elif [[ -f "package.json" ]]; then

    npm audit

elif [[ -f "go.mod" ]]; then

    go list -json -m all | nancy sleuth

elif [[ -f "pyproject.toml" ]]; then

    safety check

else

    echo "No package file found"

fi




