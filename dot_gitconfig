	name = Andrew Spratley
	email = aps831@yahoo.co.uk
[core]
	excludesfile = ~/.gitignore
	autocrlf = input
[push]
	default = simple
[pull]
	rebase = false
[diff "sopsdiffer"]
	textconv = sops -d
[init]
	defaultBranch = master
[alias]
    slog = log --graph --decorate --pretty=oneline --abbrev-commit
    ca = !git add -A && git commit -v
